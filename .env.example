# ── Signaling server (Render) ───────────────────────────────────────────────
# Cloudflare Realtime TURN credentials. Without these the server serves STUN-only
# (works on permissive networks; symmetric NATs need TURN). Create a TURN key at
# Cloudflare dashboard → Realtime → TURN, then set both here / in Render env.
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# ── Frontend (Cloudflare Pages) ─────────────────────────────────────────────
# Build-time WebSocket base of the deployed signaling server. Leave unset for
# local dev (Vite proxies /ws and /ice-servers to localhost:8080).
VITE_SIGNAL_URL=wss://duodrop-signaling.onrender.com
